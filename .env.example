# ── Azure Bot Framework ──
MICROSOFT_APP_ID=your-azure-bot-app-id
MICROSOFT_APP_PASSWORD=your-azure-bot-app-secret

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Security ──
ALLOWED_USERS=*
# Comma-separated Teams user IDs, or * for all

# ── Web Search ──
SEARCH_PROVIDER=duckduckgo
# Options: duckduckgo, tavily
TAVILY_API_KEY=

# ── Gemini (Optional for better RAG) ──
GEMINI_API_KEY=

# ── Storage ──
DATABASE_PATH=data/openclaw.db
CHROMA_PATH=data/chroma
